<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body>
<div class="login-page">
  <div class="login-card">
    <div class="login-header">
      <div class="login-logo">
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
      </div>
      <h1>Mot de passe oublié</h1>
      <p>Réinitialisation de votre accès</p>
    </div>
    <div class="login-body">
      <% if (error && error.length > 0) { %>
      <div class="alert alert-error auto-close"><%= error[0] %></div>
      <% } %>
      <% if (success && success.length > 0) { %>
      <div class="alert alert-success"><%= success[0] %></div>
      <% } %>
      <p style="font-size:13px;color:#495057;margin-bottom:16px;">Entrez votre adresse email pour recevoir les instructions de réinitialisation.</p>
      <form method="POST" action="/auth/forgot-password">
        <div class="form-group">
          <label>Adresse email <span class="required">*</span></label>
          <input type="email" name="email" class="form-control" placeholder="votre@email.ga" required>
        </div>
        <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center;margin-top:8px;">Envoyer le lien</button>
      </form>
      <div style="text-align:center;margin-top:16px;">
        <a href="/auth/login" style="font-size:13px;color:#0057A8;text-decoration:none;">← Retour à la connexion</a>
      </div>
    </div>
  </div>
</div>
<script src="/js/main.js"></script>
</body>
</html>
