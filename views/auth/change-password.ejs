<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <h1>Changer le mot de passe</h1>
    <div class="breadcrumb"><a href="/dashboard">Accueil</a> › Sécurité › Mot de passe</div>
  </div>
</div>

<% if (error && error.length > 0) { %>
<div class="alert alert-error auto-close">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/></svg>
  <%= error[0] %>
  <button class="alert-close"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
</div>
<% } %>

<% if (success && success.length > 0) { %>
<div class="alert alert-success auto-close">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
  <%= success[0] %>
</div>
<% } %>

<div style="max-width:480px;">
  <div class="form-card">
    <form method="POST" action="/auth/change-password">
      <div class="form-group mb-16">
        <label>Mot de passe actuel <span class="required">*</span></label>
        <input type="password" name="current_password" class="form-control" required>
      </div>
      <div class="form-group mb-16">
        <label>Nouveau mot de passe <span class="required">*</span></label>
        <input type="password" name="new_password" class="form-control" minlength="8" required>
        <span class="form-hint">Minimum 8 caractères</span>
      </div>
      <div class="form-group mb-16">
        <label>Confirmer le nouveau mot de passe <span class="required">*</span></label>
        <input type="password" name="confirm_password" class="form-control" minlength="8" required>
      </div>
      <div style="display:flex;gap:10px;margin-top:8px;">
        <button type="submit" class="btn btn-primary">Mettre à jour</button>
        <a href="/dashboard" class="btn btn-outline">Annuler</a>
      </div>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
