<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <h1><%= archive.id ? 'Modifier l\'archive' : 'Nouvelle archive' %></h1>
    <div class="breadcrumb">
      <a href="/dashboard">Accueil</a> ›
      <a href="/archives">Archives</a> ›
      <%= archive.id ? 'Modifier' : 'Créer' %>
    </div>
  </div>
</div>

<% if (error && error.length > 0) { %>
<div class="alert alert-error">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/></svg>
  <%= error[0] %>
  <button class="alert-close"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
</div>
<% } %>

<form method="POST" action="<%= action %>" enctype="multipart/form-data">
  <div style="display:grid;grid-template-columns:2fr 1fr;gap:16px;align-items:start;">

    <!-- Colonne principale -->
    <div>
      <!-- Informations générales -->
      <div class="form-card mb-16">
        <h3 style="font-size:14px;font-weight:600;color:#0057A8;margin-bottom:16px;padding-bottom:10px;border-bottom:2px solid #E8F0FB;display:flex;align-items:center;gap:8px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
          Informations générales
        </h3>
        <div class="form-grid">
          <div class="form-group">
            <label>Référence <span class="required">*</span></label>
            <input type="text" name="reference" class="form-control" value="<%= archive.reference || '' %>" required <%= archive.id ? 'readonly style="background:#f8f9fa;"' : '' %>>
            <span class="form-hint">Générée automatiquement</span>
          </div>
          <div class="form-group">
            <label>Type de document <span class="required">*</span></label>
            <select name="type_document" class="form-control" required>
              <option value="entrant" <%= archive.type_document === 'entrant' ? 'selected' : '' %>>↓ Courrier entrant</option>
              <option value="sortant" <%= archive.type_document === 'sortant' ? 'selected' : '' %>>↑ Courrier sortant</option>
              <option value="interne" <%= (!archive.type_document || archive.type_document === 'interne') ? 'selected' : '' %>>↔ Document interne</option>
            </select>
          </div>
          <div class="form-group form-full">
            <label>Titre <span class="required">*</span></label>
            <input type="text" name="titre" class="form-control" value="<%= archive.titre || '' %>" required placeholder="Titre du document">
          </div>
          <div class="form-group form-full">
            <label>Description</label>
            <textarea name="description" class="form-control" rows="3" placeholder="Description ou objet du document..."><%= archive.description || '' %></textarea>
          </div>
          <div class="form-group">
            <label>Catégorie</label>
            <select name="categorie_id" class="form-control">
              <option value="">-- Sélectionner --</option>
              <% categories.forEach(c => { %>
              <option value="<%= c.id %>" <%= archive.categorie_id === c.id ? 'selected' : '' %>><%= c.nom %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Service</label>
            <select name="service_id" class="form-control">
              <option value="">-- Sélectionner --</option>
              <% services.forEach(s => { %>
              <option value="<%= s.id %>" <%= archive.service_id === s.id ? 'selected' : '' %>><%= s.nom %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Expéditeur</label>
            <input type="text" name="expediteur" class="form-control" value="<%= archive.expediteur || '' %>" placeholder="Nom ou organisme">
          </div>
          <div class="form-group">
            <label>Destinataire</label>
            <input type="text" name="destinataire" class="form-control" value="<%= archive.destinataire || '' %>" placeholder="Nom ou organisme">
          </div>
          <div class="form-group">
            <label>Date du document</label>
            <input type="date" name="date_document" class="form-control" value="<%= archive.date_document ? archive.date_document.split('T')[0] : '' %>">
          </div>
          <div class="form-group">
            <label>Date de réception</label>
            <input type="date" name="date_reception" class="form-control" value="<%= archive.date_reception ? archive.date_reception.split('T')[0] : '' %>">
          </div>
          <div class="form-group form-full">
            <label>Tags / Mots-clés</label>
            <input type="text" name="tags" class="form-control" value="<%= archive.tags ? archive.tags.join(', ') : '' %>" placeholder="sport, finances, 2024 (séparés par des virgules)">
            <span class="form-hint">Séparez les tags par des virgules</span>
          </div>
        </div>
      </div>

      <!-- Pièces jointes -->
      <div class="form-card">
        <h3 style="font-size:14px;font-weight:600;color:#0057A8;margin-bottom:16px;padding-bottom:10px;border-bottom:2px solid #E8F0FB;display:flex;align-items:center;gap:8px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
          Pièces jointes
        </h3>

        <div class="file-upload-area" onclick="document.getElementById('fichiers-input').click()">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="margin:0 auto 8px;display:block;"></svg>
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#0057A8" stroke-width="1.5" style="margin:0 auto 8px;display:block;"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
          <p><strong>Cliquez ou glissez-déposez</strong> vos fichiers ici</p>
          <span>PDF, DOCX, XLSX, JPG, PNG · Max 10 MB par fichier · 10 fichiers maximum</span>
        </div>
        <input type="file" id="fichiers-input" name="fichiers" multiple accept=".pdf,.docx,.doc,.xlsx,.xls,.jpg,.jpeg,.png" style="display:none;" onchange="updateFileList(this)">
        <div id="file-list" style="margin-top:12px;"></div>
      </div>
    </div>

    <!-- Colonne latérale -->
    <div>
      <div class="form-card mb-16">
        <h3 style="font-size:14px;font-weight:600;color:#0057A8;margin-bottom:16px;padding-bottom:10px;border-bottom:2px solid #E8F0FB;">Confidentialité & Statut</h3>

        <div class="form-group mb-16">
          <label>Niveau de confidentialité</label>
          <select name="confidentialite" class="form-control">
            <option value="public" <%= archive.confidentialite === 'public' ? 'selected' : '' %>>🟢 Public</option>
            <option value="normal" <%= (!archive.confidentialite || archive.confidentialite === 'normal') ? 'selected' : '' %>>🔵 Normal</option>
            <option value="confidentiel" <%= archive.confidentialite === 'confidentiel' ? 'selected' : '' %>>🟡 Confidentiel</option>
            <option value="secret" <%= archive.confidentialite === 'secret' ? 'selected' : '' %>>🔴 Secret</option>
          </select>
        </div>

        <div style="padding:12px;background:#FEF9E0;border-radius:6px;border-left:3px solid #F4C300;">
          <div style="font-size:12px;font-weight:600;color:#8A6F00;margin-bottom:4px;">ℹ Info confidentialité</div>
          <div style="font-size:11px;color:#8A6F00;">Le niveau de confidentialité détermine qui peut accéder à ce document.</div>
        </div>
      </div>

      <div class="form-card">
        <h3 style="font-size:14px;font-weight:600;color:#0057A8;margin-bottom:16px;padding-bottom:10px;border-bottom:2px solid #E8F0FB;">Actions</h3>

        <div style="display:flex;flex-direction:column;gap:10px;">
          <button type="submit" class="btn btn-primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
            <%= archive.id ? 'Enregistrer les modifications' : 'Créer l\'archive' %>
          </button>
          <a href="/archives<%= archive.id ? '/' + archive.id : '' %>" class="btn btn-outline">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
            Annuler
          </a>
        </div>

        <div style="margin-top:16px;padding:12px;background:#E8F0FB;border-radius:6px;">
          <div style="font-size:11px;color:#0057A8;font-weight:600;">Un QR code unique sera généré automatiquement pour cette archive.</div>
        </div>
      </div>
    </div>
  </div>
</form>

<%- include('../partials/footer') %>
