<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <h1><%= archive.titre %></h1>
    <div class="breadcrumb">
      <a href="/dashboard">Accueil</a> ›
      <a href="/archives">Archives</a> ›
      <%= archive.reference %>
    </div>
  </div>
  <div style="display:flex;gap:8px;">
    <a href="/archives/<%= archive.id %>/export-pdf" class="btn btn-outline btn-sm">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
      Export PDF
    </a>
    <% if (user && (user.role === 'super_admin' || user.role === 'archiviste')) { %>
    <a href="/archives/<%= archive.id %>/modifier" class="btn btn-warning btn-sm">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
      Modifier
    </a>
    <form method="POST" action="/archives/<%= archive.id %>?_method=DELETE" data-confirm="Déplacer cette archive à la corbeille ?" style="display:inline;">
      <button type="submit" class="btn btn-danger btn-sm">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/></svg>
        Corbeille
      </button>
    </form>
    <% } %>
  </div>
</div>

<% if (success && success.length > 0) { %>
<div class="alert alert-success auto-close">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
  <%= success[0] %>
  <button class="alert-close"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
</div>
<% } %>

<!-- Bandeau infos rapides -->
<div style="display:flex;gap:10px;margin-bottom:20px;flex-wrap:wrap;">
  <span class="badge badge-bleu" style="font-size:12px;padding:6px 14px;">
    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/></svg>
    <%= archive.reference %>
  </span>
  <span class="badge <%= archive.type_document === 'entrant' ? 'badge-vert' : archive.type_document === 'sortant' ? 'badge-bleu' : 'badge-gris' %>" style="font-size:12px;padding:6px 14px;">
    <%= archive.type_document === 'entrant' ? '↓ Entrant' : archive.type_document === 'sortant' ? '↑ Sortant' : '↔ Interne' %>
  </span>
  <span class="badge confidentialite-badge <%= archive.confidentialite %>" style="font-size:12px;padding:6px 14px;">
    🔒 <%= archive.confidentialite %>
  </span>
  <span class="badge badge-<%= archive.statut %>" style="font-size:12px;padding:6px 14px;"><%= archive.statut %></span>
  <% if (archive.categorie) { %>
  <span class="badge" style="background:<%= archive.categorie.couleur %>18;color:<%= archive.categorie.couleur %>;font-size:12px;padding:6px 14px;"><%= archive.categorie.nom %></span>
  <% } %>
</div>

<div class="detail-grid">
  <!-- Colonne principale -->
  <div>
    <!-- Détails -->
    <div class="detail-section">
      <h3>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
        Informations du document
      </h3>

      <% if (archive.description) { %>
      <div style="background:#E8F0FB;border-radius:6px;padding:14px;margin-bottom:16px;font-size:13px;color:#212529;line-height:1.6;">
        <strong style="color:#0057A8;font-size:12px;text-transform:uppercase;letter-spacing:0.4px;">Description</strong><br>
        <%= archive.description %>
      </div>
      <% } %>

      <div class="detail-row">
        <span class="detail-label">Référence</span>
        <span class="detail-value" style="font-weight:700;color:#0057A8;"><%= archive.reference %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Service</span>
        <span class="detail-value"><%= archive.service ? archive.service.nom : '-' %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Expéditeur</span>
        <span class="detail-value"><%= archive.expediteur || '-' %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Destinataire</span>
        <span class="detail-value"><%= archive.destinataire || '-' %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Date du document</span>
        <span class="detail-value"><%= archive.date_document ? moment(archive.date_document).format('DD MMMM YYYY') : '-' %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Date de réception</span>
        <span class="detail-value"><%= archive.date_reception ? moment(archive.date_reception).format('DD MMMM YYYY') : '-' %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Créé par</span>
        <span class="detail-value"><%= archive.createur ? `${archive.createur.prenom} ${archive.createur.nom}` : '-' %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Date de création</span>
        <span class="detail-value"><%= moment(archive.created_at).format('DD MMMM YYYY à HH:mm') %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Dernière modification</span>
        <span class="detail-value"><%= moment(archive.updated_at).format('DD MMMM YYYY à HH:mm') %></span>
      </div>
      <% if (archive.tags && archive.tags.length > 0) { %>
      <div class="detail-row">
        <span class="detail-label">Tags</span>
        <span class="detail-value">
          <% archive.tags.forEach(tag => { %>
          <span class="badge badge-gris" style="margin-right:4px;font-size:11px;">#<%= tag %></span>
          <% }) %>
        </span>
      </div>
      <% } %>
    </div>

    <!-- Pièces jointes -->
    <div class="detail-section">
      <h3>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
        Pièces jointes (<%= fichiers.length %>)
      </h3>

      <% if (fichiers.length === 0) { %>
      <div style="text-align:center;padding:20px;color:#ADB5BD;font-size:13px;">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="display:block;margin:0 auto 8px;"><path d="M21.44 11.05l-9.19 9.19a6 6 0 0 1-8.49-8.49l9.19-9.19a4 4 0 0 1 5.66 5.66l-9.2 9.19a2 2 0 0 1-2.83-2.83l8.49-8.48"/></svg>
        Aucune pièce jointe
      </div>
      <% } %>

      <% fichiers.forEach(f => { %>
      <% 
        const ext = f.nom_original.split('.').pop().toLowerCase();
        const iconClass = ext === 'pdf' ? 'pdf' : ['docx','doc'].includes(ext) ? 'docx' : ['xlsx','xls'].includes(ext) ? 'xlsx' : 'img';
        const size = f.taille > 1048576 ? (f.taille/1048576).toFixed(1)+' MB' : (f.taille/1024).toFixed(0)+' KB';
      %>
      <div class="file-item">
        <div class="file-icon <%= iconClass %>">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>
        <div class="file-info">
          <div class="file-name"><%= f.nom_original %></div>
          <div class="file-size"><%= size %> · <%= moment(f.created_at).format('DD/MM/YYYY') %></div>
        </div>
        <a href="/archives/fichiers/<%= f.id %>/telecharger" class="btn btn-icon btn-outline btn-sm" title="Télécharger">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        </a>
        <% if (user && (user.role === 'super_admin' || user.role === 'archiviste')) { %>
        <form method="POST" action="/archives/fichiers/<%= f.id %>?_method=DELETE" data-confirm="Supprimer le fichier '<%= f.nom_original %>' ?" style="display:inline;">
          <button type="submit" class="btn btn-icon btn-sm" style="background:#FDECEE;color:#CE1126;border:1.5px solid #F5B7C0;" title="Supprimer">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/></svg>
          </button>
        </form>
        <% } %>
      </div>
      <% }) %>
    </div>

    <!-- Historique -->
    <div class="detail-section">
      <h3>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        Historique des actions
      </h3>

      <% if (historique.length === 0) { %>
      <div style="text-align:center;padding:16px;color:#ADB5BD;font-size:13px;">Aucun historique</div>
      <% } %>

      <div class="timeline">
        <% historique.forEach(h => { %>
        <div class="timeline-item">
          <div class="timeline-dot <%= h.action %>"></div>
          <div class="timeline-content">
            <div class="timeline-action">
              <%= h.utilisateur ? `${h.utilisateur.prenom} ${h.utilisateur.nom}` : 'Système' %> —
              <span style="color:<%=
                h.action === 'ajout' ? '#009A44' :
                h.action === 'modification' ? '#B8920A' :
                h.action === 'suppression' ? '#CE1126' : '#0057A8'
              %>"><%= h.action %></span>
            </div>
            <div class="timeline-time"><%= moment(h.created_at).format('DD/MM/YYYY à HH:mm') %> · <%= moment(h.created_at).fromNow() %></div>
          </div>
        </div>
        <% }) %>
      </div>
    </div>
  </div>

  <!-- Colonne latérale -->
  <div>
    <!-- QR Code -->
    <% if (archive.qr_code) { %>
    <div class="detail-section">
      <h3>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="5" height="5"/><rect x="16" y="3" width="5" height="5"/><rect x="3" y="16" width="5" height="5"/><path d="M21 16h-3a2 2 0 0 0-2 2v3"/><path d="M21 21v.01"/><path d="M12 7v3a2 2 0 0 1-2 2H7"/><path d="M3 12h.01"/><path d="M12 3h.01"/><path d="M12 16v.01"/><path d="M16 12h1"/><path d="M21 12v.01"/><path d="M12 21v-1"/></svg>
        QR Code
      </h3>
      <div class="qr-container">
        <img src="<%= archive.qr_code %>" alt="QR Code <%= archive.reference %>">
        <div style="font-size:12px;color:#ADB5BD;margin-top:8px;">Référence: <%= archive.reference %></div>
        <a href="<%= archive.qr_code %>" download="qr-<%= archive.reference %>.png" class="btn btn-outline btn-sm" style="margin-top:10px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          Télécharger QR
        </a>
      </div>
    </div>
    <% } %>

    <!-- Résumé -->
    <div class="detail-section">
      <h3>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
        Résumé
      </h3>
      <div style="display:flex;flex-direction:column;gap:10px;">
        <div style="display:flex;justify-content:space-between;font-size:13px;">
          <span style="color:#ADB5BD;">Fichiers</span>
          <span style="font-weight:600;"><%= fichiers.length %></span>
        </div>
        <div style="display:flex;justify-content:space-between;font-size:13px;">
          <span style="color:#ADB5BD;">Actions</span>
          <span style="font-weight:600;"><%= historique.length %></span>
        </div>
        <div style="display:flex;justify-content:space-between;font-size:13px;">
          <span style="color:#ADB5BD;">Créé le</span>
          <span style="font-weight:600;"><%= moment(archive.created_at).format('DD/MM/YY') %></span>
        </div>
      </div>
    </div>

    <!-- Actions rapides -->
    <div class="detail-section">
      <h3>Actions rapides</h3>
      <div style="display:flex;flex-direction:column;gap:8px;">
        <a href="/archives/<%= archive.id %>/export-pdf" class="btn btn-outline btn-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/></svg>
          Exporter en PDF
        </a>
        <% if (user && (user.role === 'super_admin' || user.role === 'archiviste')) { %>
        <a href="/archives/<%= archive.id %>/modifier" class="btn btn-warning btn-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          Modifier l'archive
        </a>
        <% } %>
        <a href="/archives" class="btn btn-outline btn-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
          Retour à la liste
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
