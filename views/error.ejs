<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/main.css">
</head>
<body style="background:#0057A8;display:flex;align-items:center;justify-content:center;min-height:100vh;">
  <div style="text-align:center;color:#fff;padding:40px;">
    <div style="font-size:80px;font-weight:800;color:#F4C300;line-height:1;margin-bottom:16px;"><%= code %></div>
    <div style="font-size:22px;font-weight:700;margin-bottom:8px;"><%= code === 404 ? 'Page introuvable' : 'Erreur serveur' %></div>
    <div style="font-size:14px;color:rgba(255,255,255,0.7);margin-bottom:32px;max-width:400px;"><%= message %></div>
    <div style="display:flex;gap:12px;justify-content:center;">
      <a href="/dashboard" style="background:#F4C300;color:#003F7D;padding:10px 24px;border-radius:8px;font-weight:700;font-size:14px;text-decoration:none;font-family:Poppins;">
        Tableau de bord
      </a>
      <a href="javascript:history.back()" style="background:rgba(255,255,255,0.15);color:#fff;padding:10px 24px;border-radius:8px;font-weight:600;font-size:14px;text-decoration:none;font-family:Poppins;">
        Retour
      </a>
    </div>
  </div>
</body>
</html>
