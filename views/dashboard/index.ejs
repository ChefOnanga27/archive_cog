<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <h1>Tableau de bord</h1>
    <div class="breadcrumb">Accueil › Tableau de bord</div>
  </div>
  <div style="display:flex;gap:8px;align-items:center;">
    <span style="font-size:12px;color:#ADB5BD;"><%= moment().format('dddd D MMMM YYYY') %></span>
    <% if (user && (user.role === 'super_admin' || user.role === 'archiviste')) { %>
    <a href="/archives/creer" class="btn btn-primary btn-sm">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Nouvelle archive
    </a>
    <% } %>
  </div>
</div>

<% if (error && error.length > 0) { %>
<div class="alert alert-error auto-close">
  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/></svg>
  <%= error[0] %>
  <button class="alert-close"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button>
</div>
<% } %>

<!-- STATS CARDS -->
<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon bleu">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
    </div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.totalArchives %></div>
      <div class="stat-label">Total Archives</div>
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-icon vert">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
    </div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.archivesActives %></div>
      <div class="stat-label">Documents actifs</div>
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-icon jaune">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
    </div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.archivesEnAttente %></div>
      <div class="stat-label">Archivés</div>
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-icon bleu">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
    </div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.totalUsers %></div>
      <div class="stat-label">Utilisateurs actifs</div>
    </div>
  </div>

  <div class="stat-card">
    <div class="stat-icon rouge">
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
    </div>
    <div class="stat-info">
      <div class="stat-value"><%= stats.corbeille %></div>
      <div class="stat-label">Corbeille</div>
    </div>
  </div>
</div>

<!-- GRAPHIQUES -->
<div class="charts-grid">
  <div class="chart-card">
    <h3>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/><line x1="2" y1="20" x2="22" y2="20"/></svg>
      Archives par mois (6 derniers mois)
    </h3>
    <div style="height:220px;position:relative;">
      <canvas id="chart-mois"></canvas>
    </div>
  </div>

  <div class="chart-card">
    <h3>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><line x1="2" y1="12" x2="22" y2="12"/></svg>
      Répartition par catégorie
    </h3>
    <div style="height:220px;position:relative;">
      <canvas id="chart-categories"></canvas>
    </div>
  </div>
</div>

<!-- CONTENU PRINCIPAL: Archives récentes + Activités -->
<div style="display:grid;grid-template-columns:2fr 1fr;gap:16px;">

  <!-- Archives récentes -->
  <div class="table-card">
    <div class="table-header">
      <h3>Archives récentes</h3>
      <a href="/archives" class="btn btn-outline btn-sm">Voir tout</a>
    </div>
    <div class="table-responsive">
      <table>
        <thead>
          <tr>
            <th>Référence</th>
            <th>Titre</th>
            <th>Catégorie</th>
            <th>Type</th>
            <th>Date</th>
            <th>Statut</th>
          </tr>
        </thead>
        <tbody>
          <% if (archivesRecentes.length === 0) { %>
          <tr>
            <td colspan="6" style="text-align:center;padding:32px;color:#ADB5BD;">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="display:block;margin:0 auto 8px;"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
              Aucune archive pour le moment
            </td>
          </tr>
          <% } %>
          <% archivesRecentes.forEach(a => { %>
          <tr>
            <td><a href="/archives/<%= a.id %>" style="color:#0057A8;font-weight:600;text-decoration:none;font-size:12px;"><%= a.reference %></a></td>
            <td style="max-width:200px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
              <a href="/archives/<%= a.id %>" style="color:#212529;text-decoration:none;"><%= a.titre %></a>
            </td>
            <td>
              <% if (a.categorie) { %>
              <span class="badge badge-bleu" style="background:<%= a.categorie.couleur %>18;color:<%= a.categorie.couleur %>;"><%= a.categorie.nom %></span>
              <% } else { %><span style="color:#ADB5BD;">-</span><% } %>
            </td>
            <td>
              <span class="badge <%= a.type_document === 'entrant' ? 'badge-vert' : a.type_document === 'sortant' ? 'badge-bleu' : 'badge-gris' %>">
                <%= a.type_document === 'entrant' ? '↓ Entrant' : a.type_document === 'sortant' ? '↑ Sortant' : '↔ Interne' %>
              </span>
            </td>
            <td style="font-size:12px;"><%= a.date_document ? moment(a.date_document).format('DD/MM/YYYY') : moment(a.created_at).format('DD/MM/YYYY') %></td>
            <td><span class="badge badge-<%= a.statut %>"><%= a.statut %></span></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Activités récentes -->
  <div class="table-card">
    <div class="table-header">
      <h3>Activités récentes</h3>
      <a href="/historique" class="btn btn-outline btn-sm">Voir tout</a>
    </div>
    <div style="padding:12px 0;max-height:380px;overflow-y:auto;">
      <% if (activitesRecentes.length === 0) { %>
      <div style="text-align:center;padding:24px;color:#ADB5BD;font-size:13px;">Aucune activité</div>
      <% } %>
      <% activitesRecentes.forEach(h => { %>
      <div style="display:flex;gap:12px;padding:10px 16px;border-bottom:1px solid #f0f0f0;">
        <div style="width:32px;height:32px;border-radius:50%;background:<%=
          h.action === 'ajout' ? '#E6F5ED' :
          h.action === 'modification' ? '#FEF9E0' :
          h.action === 'suppression' ? '#FDECEE' :
          h.action === 'connexion' ? '#E8F0FB' : '#F8F9FA'
        %>;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <% if (h.action === 'ajout') { %>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#009A44" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          <% } else if (h.action === 'modification') { %>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#B8920A" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
          <% } else if (h.action === 'suppression') { %>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#CE1126" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/></svg>
          <% } else { %>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0057A8" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <% } %>
        </div>
        <div style="flex:1;min-width:0;">
          <div style="font-size:12px;font-weight:600;color:#212529;">
            <%= h.utilisateur ? `${h.utilisateur.prenom} ${h.utilisateur.nom}` : 'Système' %>
            <span style="font-weight:400;color:#ADB5BD;">— <%= h.action %></span>
          </div>
          <div style="font-size:11px;color:#ADB5BD;margin-top:2px;"><%= moment(h.created_at).fromNow() %></div>
        </div>
      </div>
      <% }) %>
    </div>
  </div>
</div>

<script>
  const moisData = <%- JSON.stringify(moisStats) %>;
  const categorieData = <%- JSON.stringify(categorieStats) %>;
  document.addEventListener('DOMContentLoaded', () => {
    initCharts(moisData, categorieData);
  });
</script>

<%- include('../partials/footer') %>
