<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <h1>Catégories</h1>
    <div class="breadcrumb"><a href="/dashboard">Accueil</a> › Paramètres › Catégories</div>
  </div>
</div>

<% if (success && success.length > 0) { %>
<div class="alert alert-success auto-close"><%= success[0] %><button class="alert-close"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>
<% } %>
<% if (error && error.length > 0) { %>
<div class="alert alert-error auto-close"><%= error[0] %></div>
<% } %>

<!-- Onglets settings -->
<div style="display:flex;gap:8px;margin-bottom:20px;">
  <a href="/parametres/categories" class="btn btn-primary btn-sm">Catégories</a>
  <a href="/parametres/services" class="btn btn-outline btn-sm">Services</a>
</div>

<div style="display:grid;grid-template-columns:340px 1fr;gap:16px;align-items:start;">
  <!-- Formulaire ajout -->
  <div class="form-card">
    <h3 style="font-size:14px;font-weight:600;color:#0057A8;margin-bottom:16px;padding-bottom:10px;border-bottom:2px solid #E8F0FB;">Ajouter une catégorie</h3>
    <form method="POST" action="/parametres/categories">
      <div class="form-group mb-16">
        <label>Nom <span class="required">*</span></label>
        <input type="text" name="nom" class="form-control" required placeholder="Ex: Finances">
      </div>
      <div class="form-group mb-16">
        <label>Description</label>
        <textarea name="description" class="form-control" rows="2" placeholder="Description de la catégorie"></textarea>
      </div>
      <div class="form-group mb-16">
        <label>Couleur</label>
        <div style="display:flex;gap:8px;align-items:center;">
          <input type="color" name="couleur" value="#0057A8" style="width:48px;height:36px;border:1.5px solid #DEE2E6;border-radius:6px;padding:2px;cursor:pointer;">
          <span style="font-size:12px;color:#ADB5BD;">Couleur du badge</span>
        </div>
      </div>
      <button type="submit" class="btn btn-primary">
        <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Ajouter
      </button>
    </form>
  </div>

  <!-- Liste des catégories -->
  <div class="table-card">
    <div class="table-header">
      <h3>Catégories (<%= categories.length %>)</h3>
    </div>
    <div class="table-responsive">
      <table>
        <thead>
          <tr>
            <th>Couleur</th>
            <th>Nom</th>
            <th>Description</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% if (categories.length === 0) { %>
          <tr><td colspan="4" style="text-align:center;padding:32px;color:#ADB5BD;">Aucune catégorie</td></tr>
          <% } %>
          <% categories.forEach(c => { %>
          <tr>
            <td>
              <div style="width:24px;height:24px;border-radius:6px;background:<%= c.couleur %>;"></div>
            </td>
            <td>
              <span class="badge" style="background:<%= c.couleur %>18;color:<%= c.couleur %>;font-size:12px;"><%= c.nom %></span>
            </td>
            <td style="font-size:12px;color:#ADB5BD;max-width:200px;"><%= c.description || '-' %></td>
            <td>
              <form method="POST" action="/parametres/categories/<%= c.id %>?_method=DELETE" data-confirm="Supprimer la catégorie '<%= c.nom %>' ? Les archives liées ne seront pas supprimées.">
                <button type="submit" class="btn btn-icon btn-sm" style="background:#FDECEE;color:#CE1126;border:1.5px solid #F5B7C0;" title="Supprimer">
                  <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/></svg>
                </button>
              </form>
            </td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
