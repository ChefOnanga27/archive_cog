<%- include('../partials/header') %>

<div class="page-header">
  <div>
    <h1><%= user_edit.id ? 'Modifier l\'utilisateur' : 'Nouvel utilisateur' %></h1>
    <div class="breadcrumb"><a href="/dashboard">Accueil</a> › <a href="/utilisateurs">Utilisateurs</a> › <%= user_edit.id ? 'Modifier' : 'Créer' %></div>
  </div>
</div>

<% if (error && error.length > 0) { %>
<div class="alert alert-error"><%= error[0] %><button class="alert-close"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg></button></div>
<% } %>

<div style="max-width:600px;">
  <div class="form-card">
    <form method="POST" action="<%= action %>">
      <div class="form-grid">
        <div class="form-group">
          <label>Prénom <span class="required">*</span></label>
          <input type="text" name="prenom" class="form-control" value="<%= user_edit.prenom || '' %>" required>
        </div>
        <div class="form-group">
          <label>Nom <span class="required">*</span></label>
          <input type="text" name="nom" class="form-control" value="<%= user_edit.nom || '' %>" required>
        </div>
        <div class="form-group form-full">
          <label>Email <span class="required">*</span></label>
          <input type="email" name="email" class="form-control" value="<%= user_edit.email || '' %>" required>
        </div>
        <div class="form-group">
          <label><%= user_edit.id ? 'Nouveau mot de passe' : 'Mot de passe' %> <%= !user_edit.id ? '<span class="required">*</span>' : '' %></label>
          <input type="password" name="<%= user_edit.id ? 'new_password' : 'password' %>" class="form-control" <%= !user_edit.id ? 'required' : '' %> minlength="8" placeholder="<%= user_edit.id ? 'Laisser vide pour ne pas changer' : 'Min. 8 caractères' %>">
        </div>
        <div class="form-group">
          <label>Rôle <span class="required">*</span></label>
          <select name="role" class="form-control" required>
            <option value="consultation" <%= user_edit.role === 'consultation' ? 'selected' : '' %>>👁 Consultation</option>
            <option value="archiviste" <%= user_edit.role === 'archiviste' ? 'selected' : '' %>>📁 Archiviste</option>
            <option value="super_admin" <%= user_edit.role === 'super_admin' ? 'selected' : '' %>>👑 Super Admin</option>
          </select>
        </div>
        <div class="form-group form-full">
          <label>Service / Département</label>
          <input type="text" name="service" class="form-control" value="<%= user_edit.service || '' %>" placeholder="Direction Générale, Finances...">
        </div>
        <% if (user_edit.id) { %>
        <div class="form-group form-full">
          <label>Statut du compte</label>
          <select name="actif" class="form-control">
            <option value="true" <%= user_edit.actif ? 'selected' : '' %>>✓ Actif</option>
            <option value="false" <%= !user_edit.actif ? 'selected' : '' %>>✗ Inactif</option>
          </select>
        </div>
        <% } %>
      </div>

      <div style="display:flex;gap:10px;margin-top:20px;">
        <button type="submit" class="btn btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/></svg>
          <%= user_edit.id ? 'Enregistrer' : 'Créer l\'utilisateur' %>
        </button>
        <a href="/utilisateurs" class="btn btn-outline">Annuler</a>
      </div>
    </form>
  </div>

  <div class="alert alert-info mt-16">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
    <div>
      <strong>Niveaux d'accès :</strong><br>
      <span style="font-size:12px;">👑 Super Admin : accès complet · 📁 Archiviste : gestion des documents · 👁 Consultation : lecture seule</span>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
